# Basics
NETWORK_NAME=reverse-proxy
RESTART=no
DASHBOARD=true
HOST=localhost
DOCKER_SOCKET=/var/run/docker.sock
# SSL
ACME_EMAIL=
# RES-224 (restaurant-cms): shared bearer secret for the HTTP dynamic provider.
# Must match NUXT_TRAEFIK_PROVIDER_SECRET on the restaurant-cms homepage service.
TRAEFIK_PROVIDER_SECRET=legion-traefik-provider-secret
# Override if the restaurant-cms homepage is reachable under a different name.
# RCMS_TRAEFIK_PROVIDER_ENDPOINT=http://restaurant-cms-homepage:3000/internal/traefik/dynamic
